<% layout("layouts/boilerplate.ejs") %>

<body>
    <div class="container mt-4 container-result">
        <h2 class="text-center mb-4 cth2">Search Results</h2>
        <hr>

        <% if (results.length === 0) { %>
            <p class="text-center text-danger">No doctors found matching your criteria.</p>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                <% results.forEach(doctor => { %>
                    <div class="col">
                        <div class="card  h-100 shadow-sm card-result">
                            <img src="<%= doctor.image ? doctor.image : '/image/defaultimg.jpg' %>" class="card-result-img-top" alt="<%= doctor.name %>" style="height: 250px; object-fit: cover;">
                            <div class="card-body card-body-result">
                                <h5 class="card-title card-title-result"><%= doctor.name %></h5>
                                <p class="card-text card-text-result"><%= doctor.description %></p>
                                <p><strong>Specialist:</strong> <%= doctor.specialist %></p>
                                <p><strong>Division:</strong> <%= doctor.division %></p>
                                <p><strong>Location:</strong> <%= doctor.location %></p>
                                <p>
                                    <strong>Booking Fee:</strong> 
                                    <span class="text-success">BDT <%= doctor.booking_amount?.new || 0 %></span> (New) | 
                                    <span class="text-muted">BDT <%= doctor.booking_amount?.old || 0 %></span> (Old)
                                </p>
                            </div>
                            <div class="card-footer text-center" style="background-color: blue;">
                                <a href="/Doctor/<%= doctor._id %>" class="btn btn-primary btn-result ">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>

    
</body>
