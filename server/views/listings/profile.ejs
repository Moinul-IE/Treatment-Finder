<% layout("layouts/boilerplate.ejs") %>

<body>
    <div class="container mt-4">
        <h2 class="text-center mb-4">User  Profile</h2>
        <hr>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="<%= doctor.image ? doctor.image : '/image/defaultimg.jpg' %>" class="card-img-top" alt="<%= doctor.name %>" style="height: 250px; object-fit: cover;">
                    <div class="card-body card-body-result">
                        <h5 class="card-title card-title-result"><%= doctor.name %></h5>
                        <p class="card-text card-text-result"><%= doctor.description %></p>
                        <p><strong>Specialist:</strong> <%= doctor.specialist %></p>
                        <p><strong>Division:</strong> <%= doctor.division %></p>
                        <p><strong>Location:</strong> <%= doctor.location %></p>
                        <p>
                            <strong>Booking Fee:</strong> 
                            <span class="text-success">BDT <%= doctor.booking_amount?.new || 0 %></span> (New) | 
                            <span class="text-muted">BDT <%= doctor.booking_amount?.old || 0 %></span> (Old)
                        </p>
                    </div>
                    <div class="card-footer text-center">
                        <a href="/editProfile" class="btn btn-primary">Edit Profile</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>